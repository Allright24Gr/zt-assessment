# ─────────────────────────────────────────────────────────────────────────────
# 백엔드
# ─────────────────────────────────────────────────────────────────────────────
API_BASE=http://localhost:8000

# JWT 서명 키 (P0-1). 32+ char 권장. 미설정 시 부팅마다 임시 키 → 모든 토큰 무효.
# `openssl rand -hex 48` 또는 `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=
# JWT 토큰 만료. 기본 access 8h / refresh 30d.
ZTA_JWT_ACCESS_HOURS=8
ZTA_JWT_REFRESH_DAYS=30

# 로그인 IP별 잠금 정책 (P0-4). 30분 윈도우 내 50회 실패 시 30분 잠금.
ZTA_LOGIN_IP_MAX=50
ZTA_LOGIN_IP_WINDOW=1800
ZTA_LOGIN_IP_LOCK=1800

# Shuffle 등이 결과를 webhook으로 POST할 때 검증하는 토큰. 운영 시 32+ 글자 권장.
# 비워두면 모든 webhook 요청이 503으로 차단된다(fail-closed).
# 로컬 개발 중 토큰 없이 테스트하려면 ZTA_DEV_ALLOW_UNAUTH_WEBHOOK=true 추가.
INTERNAL_API_TOKEN=
# ZTA_DEV_ALLOW_UNAUTH_WEBHOOK=true   # ← dev 한정. 운영에서 절대 활성 금지.

# CORS 허용 출처. wildcard(*) 사용 시 브라우저가 credentialed 요청을 차단하므로
# 운영에서는 명시적 도메인 콤마 구분 권장: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# DB
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zt_assessment
DB_USER=
DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# 진단 도구 — 기본값(데모 모드)
# 사용자가 NewAssessment에서 직접 입력하면 세션 단위로 우선 사용된다.
# 아래 값은 사용자 입력이 없을 때만 fallback으로 적용.
# ─────────────────────────────────────────────────────────────────────────────

# Keycloak (사용자가 NewAssessment에서 자기 IdP 등록 가능)
KEYCLOAK_URL=http://localhost:8443
KEYCLOAK_REALM=
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=

# Wazuh (사용자가 NewAssessment에서 자기 SIEM 등록 가능)
WAZUH_URL=https://localhost:55000
WAZUH_USER=
WAZUH_PASSWORD=

# MS Entra ID (사용자가 NewAssessment에서 자기 tenant 등록 가능)
# tenant_id: GUID 또는 *.onmicrosoft.com 도메인. App registration > certificates & secrets 에서 client_secret 발급.
# 필요한 Graph API 권한: Application.Read.All, Directory.Read.All, Policy.Read.All, AuditLog.Read.All
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Okta (사용자가 NewAssessment에서 자기 Okta 등록 가능)
# domain: <subdomain>.okta.com / .oktapreview.com 등. Security > API > Tokens 에서 SSWS 토큰 발급.
# 필요한 권한: Read-only Admin (Users, Groups, Apps, Policies 조회 가능 수준)
OKTA_DOMAIN=
OKTA_API_TOKEN=

# Splunk (사용자가 NewAssessment에서 자기 Splunk 등록 가능)
# URL: Splunk REST API 포트(기본 8089). user/password 또는 token 중 하나 사용.
# 필요한 권한: 검색 가능 사용자 + admin_all_objects 캡 (saved_searches 조회용)
SPLUNK_URL=
SPLUNK_USER=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=

# Shuffle (선택 — 미설정 시 backend 직접 collector 실행)
SHUFFLE_URL=http://localhost:3001
SHUFFLE_API_KEY=

# Nmap/Trivy 래퍼 (우리 EC2 위 컨테이너. URL 자체는 변경 거의 없음)
NMAP_WRAPPER_URL=http://nmap-wrapper:8001
TRIVY_WRAPPER_URL=http://trivy-wrapper:8002

# 사용자 입력 없을 때 사용할 데모 스캔 대상
NMAP_TARGET=127.0.0.1
TRIVY_TARGET=nginx:latest

# 도구 미연결(placeholder) 가드를 강제 우회하고 싶을 때만 true (실제 운영에서 비권장)
# ZTA_FORCE_REAL_COLLECTION=true

# ─────────────────────────────────────────────────────────────────────────────
# 이메일 발송 (AWS SES)
# - EC2 IAM role 사용 시 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 는 비워두면 됨.
# - EMAIL_DRY_RUN=true 면 실제 발송 대신 콘솔에 본문만 출력 (개발/시연용).
#   미설정 + AWS_ACCESS_KEY_ID 없음 → 안전하게 DRY_RUN으로 동작.
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@readyz-t.example.com
EMAIL_DRY_RUN=                  # 'true' 시 콘솔 출력만, 운영 시 빈 값
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=              # EC2 IAM role 사용 시 생략
AWS_SECRET_ACCESS_KEY=
FRONTEND_BASE_URL=http://localhost:8080
